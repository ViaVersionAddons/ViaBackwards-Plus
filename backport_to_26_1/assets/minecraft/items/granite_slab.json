{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "minecraft:cinnabar_slab",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:block/cinnabar_slab"
        }
      },
      {
        "when": "minecraft:polished_cinnabar_slab",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:block/polished_cinnabar_slab"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:block/granite_slab"
    }
  }
}
