{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "minecraft:copper_horse_armor",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/copper_horse_armor"
        }
      },
      {
        "when": "minecraft:iron_nautilus_armor",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/iron_nautilus_armor"
        }
      },
      {
        "when": "minecraft:copper_nautilus_armor",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/copper_nautilus_armor"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/iron_horse_armor"
    }
  }
}
